###############################################################################
# NPR-70 FreeRTOS Port - Git Ignore File
###############################################################################

# Build directories
build.log
BUILD/
build/
Build/
out/
bin/
obj/

# Build artifacts
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.lss
*.sym
*.a
*.so
*.dll
*.dylib

# Dependency files
*.dep

###############################################################################
# FreeRTOS and STM32 HAL (downloaded dependencies - DO NOT COMMIT)
###############################################################################

# FreeRTOS Kernel (downloaded via script)
Middleware/FreeRTOS/

# STM32 HAL Drivers (downloaded via script)
Drivers/STM32L4xx_HAL_Driver/
Drivers/CMSIS/

CMSIS/*

# Note: Only ignore if downloaded. If you customize HAL config files,
# you may want to track those specific files by adding exceptions like:
# !Drivers/STM32L4xx_HAL_Driver/Inc/stm32l4xx_hal_conf.h

